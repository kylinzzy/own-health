/* ========== 健康分析页面 - 清爽浅绿色 ========== */

/* 报告标签页 */
.report-tabs {
  display: flex;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 4px;
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px;
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  box-shadow: 0 2px 8px rgba(76, 175, 80, 0.3);
}

.tab-icon {
  font-size: var(--font-md);
}

.tab-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: var(--text-white);
  font-weight: 600;
}

/* BMI卡片 */
.bmi-card {
  background: linear-gradient(135deg, #4CAF50 0%, #43A047 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-2xl) var(--space-xl);
  margin-bottom: var(--space-lg);
  color: var(--text-white);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.bmi-card::before {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.bmi-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
}

.bmi-title {
  font-size: var(--font-md);
  opacity: 0.9;
  font-weight: 600;
}

.bmi-value {
  font-size: var(--font-4xl);
  font-weight: 800;
  letter-spacing: -1px;
}

.bmi-category {
  font-size: var(--font-xl);
  font-weight: 700;
  margin-bottom: var(--space-sm);
}

.bmi-advice {
  font-size: var(--font-sm);
  opacity: 0.9;
  line-height: 1.6;
  font-weight: 500;
}

/* 评分卡片 */
.score-card {
  background: var(--bg-white);
  border-radius: var(--radius-xl);
  padding: var(--space-2xl);
  margin-bottom: var(--space-lg);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.score-circle {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-lg);
  box-shadow: 0 6px 20px rgba(76, 175, 80, 0.3);
}

.score-value {
  font-size: var(--font-4xl);
  font-weight: 800;
  color: var(--text-white);
  line-height: 1;
}

.score-label {
  font-size: var(--font-xs);
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4px;
  font-weight: 500;
}

.score-level {
  font-size: var(--font-xl);
  font-weight: 700;
}

/* 维度评分 */
.dimensions-card {
  margin-bottom: var(--space-lg);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-lg);
}

.dimension-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.dimension-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.dimension-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dimension-name {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
}

.dimension-score {
  font-size: var(--font-base);
  font-weight: 700;
}

.dimension-bar {
  width: 100%;
  height: 8px;
  background: var(--gray-200);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.dimension-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.5s ease;
}

.dimension-assessment {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

/* 数据摘要 */
.summary-card {
  margin-bottom: var(--space-lg);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-md);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.summary-value {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--primary-dark);
}

.summary-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 4px;
  font-weight: 500;
}

/* 建议卡片 */
.suggestions-card {
  margin-bottom: var(--space-lg);
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md) var(--space-lg);
  background: var(--primary-lightest);
  border-radius: var(--radius-sm);
}

.suggestion-bullet {
  color: var(--primary);
  font-size: var(--font-lg);
  line-height: 1.4;
  flex-shrink: 0;
  font-weight: 700;
}

.suggestion-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--primary-darker);
  line-height: 1.6;
  font-weight: 500;
}

/* 周总结样式 */
.weekly-weight-card {
  margin-bottom: var(--space-lg);
}

.weight-change-display {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: var(--space-lg) 0;
}

.weight-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.weight-stat .stat-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-bottom: 6px;
  font-weight: 600;
}

.weight-stat .stat-value {
  font-size: var(--font-2xl);
  font-weight: 800;
  color: var(--text-primary);
}

.weight-stat .stat-value.down {
  color: var(--primary-dark);
}

.weight-stat .stat-value.up {
  color: var(--danger);
}

.weight-change-arrow {
  font-size: var(--font-2xl);
}

.change-icon.down {
  color: var(--primary);
}

.change-icon.up {
  color: var(--danger);
}

.weight-range {
  text-align: center;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding-top: var(--space-md);
  border-top: 1px solid var(--gray-200);
  font-weight: 500;
}

/* 周统计 */
.weekly-stats-card {
  margin-bottom: var(--space-lg);
}

.weekly-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-md);
}

.weekly-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-lg) var(--space-sm);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
}

.weekly-stat-value {
  font-size: var(--font-2xl);
  font-weight: 800;
  color: var(--primary-dark);
}

.weekly-stat-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 4px;
  font-weight: 600;
}

/* 进度卡片 */
.progress-card {
  margin-bottom: var(--space-lg);
}

.progress-display {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  margin-bottom: var(--space-lg);
}

.progress-circle {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}

.progress-percent {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--text-white);
}

.progress-info {
  flex: 1;
}

.progress-target {
  display: block;
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-bottom: 4px;
  font-weight: 600;
}

.progress-diff {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

/* 评估卡片 */
.assessment-card {
  margin-bottom: var(--space-lg);
}

.assessment-text {
  font-size: var(--font-base);
  color: var(--text-primary);
  line-height: 1.7;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px var(--space-xl);
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-lg);
}

.empty-icon {
  font-size: 56px;
  margin-bottom: var(--space-lg);
  opacity: 0.4;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-weight: 600;
}

.empty-subtext {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}
