/* 健康分析页面样式 */

/* 报告标签页 */
.report-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 12px;
  padding: 4px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px;
  border-radius: 8px;
  transition: all 0.2s;
}

.tab-item.active {
  background: #2ECC71;
}

.tab-icon {
  font-size: 16px;
}

.tab-label {
  font-size: 14px;
  color: #7F8C8D;
}

.tab-item.active .tab-label {
  color: #FFFFFF;
  font-weight: 500;
}

/* BMI卡片 */
.bmi-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 12px;
  color: #FFFFFF;
  text-align: center;
}

.bmi-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8px;
  margin-bottom: 8px;
}

.bmi-title {
  font-size: 14px;
  opacity: 0.9;
}

.bmi-value {
  font-size: 36px;
  font-weight: 700;
}

.bmi-category {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 8px;
}

.bmi-advice {
  font-size: 13px;
  opacity: 0.9;
  line-height: 1.5;
}

/* 评分卡片 */
.score-card {
  background: #FFFFFF;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 12px;
  text-align: center;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.score-circle {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 12px;
  box-shadow: 0 4px 16px rgba(46, 204, 113, 0.3);
}

.score-value {
  font-size: 40px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

.score-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4px;
}

.score-level {
  font-size: 18px;
  font-weight: 600;
}

/* 维度评分 */
.dimensions-card {
  margin-bottom: 12px;
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 14px;
}

.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.dimension-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.dimension-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dimension-name {
  font-size: 14px;
  color: #2C3E50;
}

.dimension-score {
  font-size: 14px;
  font-weight: 600;
}

.dimension-bar {
  width: 100%;
  height: 8px;
  background: #ECF0F1;
  border-radius: 4px;
  overflow: hidden;
}

.dimension-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.5s ease;
}

.dimension-assessment {
  font-size: 12px;
  color: #7F8C8D;
}

/* 数据摘要 */
.summary-card {
  margin-bottom: 12px;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.summary-value {
  font-size: 20px;
  font-weight: 700;
  color: #2ECC71;
}

.summary-label {
  font-size: 11px;
  color: #7F8C8D;
  margin-top: 2px;
}

/* 建议卡片 */
.suggestions-card {
  margin-bottom: 12px;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 10px 12px;
  background: #F8F9FA;
  border-radius: 8px;
}

.suggestion-bullet {
  color: #2ECC71;
  font-size: 16px;
  line-height: 1.4;
  flex-shrink: 0;
}

.suggestion-text {
  flex: 1;
  font-size: 13px;
  color: #2C3E50;
  line-height: 1.5;
}

/* 周总结样式 */
.weekly-weight-card {
  margin-bottom: 12px;
}

.weight-change-display {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16px 0;
}

.weight-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.weight-stat .stat-label {
  font-size: 12px;
  color: #7F8C8D;
  margin-bottom: 4px;
}

.weight-stat .stat-value {
  font-size: 24px;
  font-weight: 700;
  color: #2C3E50;
}

.weight-stat .stat-value.down {
  color: #2ECC71;
}

.weight-stat .stat-value.up {
  color: #E74C3C;
}

.weight-change-arrow {
  font-size: 24px;
}

.change-icon.down {
  color: #2ECC71;
}

.change-icon.up {
  color: #E74C3C;
}

.weight-range {
  text-align: center;
  font-size: 13px;
  color: #7F8C8D;
  padding-top: 10px;
  border-top: 1px solid #F5F5F5;
}

/* 周统计 */
.weekly-stats-card {
  margin-bottom: 12px;
}

.weekly-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.weekly-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 12px;
  background: #F8F9FA;
  border-radius: 8px;
}

.weekly-stat-value {
  font-size: 22px;
  font-weight: 700;
  color: #2ECC71;
}

.weekly-stat-label {
  font-size: 11px;
  color: #7F8C8D;
  margin-top: 4px;
}

/* 进度卡片 */
.progress-card {
  margin-bottom: 12px;
}

.progress-display {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 12px;
}

.progress-circle {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.progress-percent {
  font-size: 20px;
  font-weight: 700;
  color: #FFFFFF;
}

.progress-info {
  flex: 1;
}

.progress-target {
  display: block;
  font-size: 14px;
  color: #2C3E50;
  margin-bottom: 4px;
}

.progress-diff {
  font-size: 13px;
  color: #7F8C8D;
}

.progress-bar {
  width: 100%;
  height: 10px;
  background: #ECF0F1;
  border-radius: 5px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2ECC71, #27AE60);
  border-radius: 5px;
  transition: width 0.5s ease;
}

/* 评估卡片 */
.assessment-card {
  margin-bottom: 12px;
}

.assessment-text {
  font-size: 14px;
  color: #2C3E50;
  line-height: 1.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 16px;
  background: #FFFFFF;
  border-radius: 12px;
  margin-bottom: 12px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 15px;
  color: #2C3E50;
  margin-bottom: 6px;
}

.empty-subtext {
  font-size: 13px;
  color: #7F8C8D;
  text-align: center;
}
