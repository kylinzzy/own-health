/* ========== 体重管理页面 - 清爽浅绿色 ========== */

/* 当前体重卡片 */
.current-weight-card {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 50%, #43A047 100%);
  border-radius: var(--radius-xl);
  padding: 32px var(--space-xl);
  margin-bottom: var(--space-lg);
  margin-top: var(--space-sm);
  color: var(--text-white);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.current-weight-card::before {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.current-weight-card::after {
  content: '';
  position: absolute;
  bottom: -40px;
  left: -20px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.weight-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: var(--space-sm);
  position: relative;
  z-index: 1;
}

.weight-value {
  font-size: 56px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2px;
}

.weight-unit {
  font-size: var(--font-lg);
  margin-left: 4px;
  opacity: 0.85;
  font-weight: 500;
}

.weight-change {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-bottom: var(--space-lg);
  position: relative;
  z-index: 1;
}

.change-icon {
  font-size: var(--font-md);
}

.change-icon.down {
  color: #C8E6C9;
}

.change-icon.up {
  color: #FFCDD2;
}

.change-value {
  font-size: var(--font-lg);
  font-weight: 700;
}

.change-value.down {
  color: #C8E6C9;
}

.change-value.up {
  color: #FFCDD2;
}

.change-label {
  font-size: var(--font-sm);
  opacity: 0.75;
  font-weight: 500;
}

.weight-target {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  padding-top: var(--space-lg);
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  position: relative;
  z-index: 1;
}

.target-label {
  font-size: var(--font-sm);
  opacity: 0.8;
  font-weight: 500;
}

.target-value {
  font-size: var(--font-md);
  font-weight: 700;
}

.target-diff {
  font-size: var(--font-sm);
  opacity: 0.7;
  font-weight: 500;
}

/* 统计行 */
.stats-row {
  display: flex;
  gap: var(--space-md);
  margin-bottom: var(--space-lg);
}

.stat-card {
  flex: 1;
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  text-align: center;
  box-shadow: var(--shadow-card);
}

.stat-card .stat-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-bottom: 6px;
  font-weight: 600;
}

.stat-card .stat-value {
  font-size: var(--font-2xl);
  font-weight: 800;
  color: var(--primary-dark);
  line-height: 1.1;
}

.stat-card .stat-unit {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-left: 2px;
  font-weight: 500;
}

/* 图表卡片 */
.chart-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.chart-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.time-range-switch {
  display: flex;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 3px;
}

.range-btn {
  padding: 6px 18px;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  border-radius: 6px;
  font-weight: 500;
  transition: all 0.2s;
}

.range-btn.active {
  background: var(--bg-white);
  color: var(--primary-dark);
  font-weight: 700;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
}

.chart-container {
  position: relative;
}

.weight-chart {
  width: 100%;
  height: 220px;
}

.chart-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px var(--space-xl);
}

.chart-empty .empty-icon {
  font-size: 48px;
  margin-bottom: var(--space-md);
  opacity: 0.4;
}

.chart-empty .empty-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

/* 周总结 */
.weekly-report {
  margin-bottom: var(--space-lg);
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.report-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.report-date {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
}

.report-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.report-row {
  display: flex;
  gap: var(--space-lg);
}

.report-item {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.report-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-bottom: 4px;
  font-weight: 600;
}

.report-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.report-value.down {
  color: var(--primary-dark);
}

.report-value.up {
  color: var(--danger);
}

.report-progress {
  margin-top: var(--space-sm);
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  font-weight: 500;
}

.report-assessment {
  background: var(--primary-lightest);
  border-radius: var(--radius-sm);
  padding: var(--space-md) var(--space-lg);
  font-size: var(--font-sm);
  color: var(--primary-darker);
  line-height: 1.6;
  font-weight: 500;
}

/* 记录列表 */
.records-section {
  margin-bottom: 80px;
}

.records-list {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.record-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  border-bottom: 1px solid var(--gray-100);
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  width: 70px;
  flex-shrink: 0;
}

.record-date {
  display: block;
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
}

.record-weekday {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
  font-weight: 500;
}

.record-center {
  flex: 1;
  text-align: center;
}

.record-weight {
  display: block;
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--primary-dark);
}

.record-bodyfat {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
  font-weight: 500;
}

.record-right {
  width: 80px;
  text-align: right;
  flex-shrink: 0;
}

.record-note {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-bottom: var(--space-xs);
}

.delete-btn {
  font-size: var(--font-sm);
  color: var(--danger);
  padding: 4px 10px;
  font-weight: 500;
}
