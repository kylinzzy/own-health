<view class="container">
  <!-- 欢迎区域 -->
  <view class="welcome-section">
    <view class="welcome-top">
      <view class="welcome-left">
        <text class="welcome-date">{{today}} {{weekDay}}</text>
        <text class="welcome-text">保持健康节奏</text>
      </view>
      <view class="welcome-avatar">
        <text class="avatar-icon">🌿</text>
      </view>
    </view>
  </view>

  <!-- 今日数据概览 -->
  <view class="overview-card">
    <view class="overview-label-row">
      <text class="overview-title">今日概览</text>
      <text class="overview-badge">实时</text>
    </view>
    <view class="overview-stats">
      <view class="overview-item">
        <view class="overview-icon-wrap intake-bg">
          <text class="overview-emoji">🍽</text>
        </view>
        <text class="overview-value">{{dailyStats.intake}}</text>
        <text class="overview-label">摄入(千卡)</text>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <view class="overview-icon-wrap burn-bg">
          <text class="overview-emoji">🔥</text>
        </view>
        <text class="overview-value">{{dailyStats.burn}}</text>
        <text class="overview-label">消耗(千卡)</text>
      </view>
      <view class="overview-divider"></view>
      <view class="overview-item">
        <view class="overview-icon-wrap deficit-bg">
          <text class="overview-emoji">⚖</text>
        </view>
        <text class="overview-value {{dailyStats.deficit < 0 ? 'value-green' : 'value-red'}}">
          {{dailyStats.deficit > 0 ? '+' : ''}}{{dailyStats.deficit}}
        </text>
        <text class="overview-label">缺口(千卡)</text>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section-header">
    <text class="section-title">快捷记录</text>
  </view>
  <view class="quick-actions">
    <view
      wx:for="{{quickActions}}"
      wx:key="label"
      class="action-item"
      data-path="{{item.path}}"
      bindtap="onQuickAction"
    >
      <view class="action-icon-wrap" style="background: {{item.bg}}">
        <text class="action-emoji">{{item.icon}}</text>
      </view>
      <text class="action-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="section-header">
    <text class="section-title">功能中心</text>
  </view>
  <view class="feature-grid">
    <view
      wx:for="{{featureCards}}"
      wx:key="title"
      class="feature-card"
      data-path="{{item.path}}"
      bindtap="onFeatureCard"
    >
      <view class="feature-icon-wrap" style="background: {{item.bg}}">
        <text class="feature-emoji">{{item.icon}}</text>
      </view>
      <view class="feature-info">
        <text class="feature-title">{{item.title}}</text>
        <text class="feature-desc">{{item.desc}}</text>
      </view>
      <view class="feature-arrow-wrap">
        <text class="feature-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 最新体重 -->
  <view class="weight-card" wx:if="{{latestWeight}}">
    <view class="weight-left">
      <view class="weight-icon-wrap">
        <text class="weight-emoji">⚖</text>
      </view>
      <view class="weight-info">
        <text class="weight-label">最新体重</text>
        <text class="weight-date">{{latestWeight.date}}</text>
      </view>
    </view>
    <view class="weight-right">
      <text class="weight-number">{{latestWeight.weight}}</text>
      <text class="weight-unit">kg</text>
      <text class="weight-bodyfat" wx:if="{{latestWeight.bodyFat}}">体脂{{latestWeight.bodyFat}}%</text>
    </view>
  </view>

  <!-- 今日饮食预览 -->
  <view class="preview-card" wx:if="{{todayDiet.length > 0}}">
    <view class="preview-header">
      <view class="preview-title-row">
        <view class="preview-icon-wrap diet-bg">
          <text class="preview-emoji">🥗</text>
        </view>
        <text class="preview-title">今日饮食</text>
      </view>
      <text class="preview-count">{{todayDiet.length}}项</text>
    </view>
    <view class="preview-list">
      <view
        wx:for="{{todayDiet}}"
        wx:key="id"
        class="preview-item"
      >
        <text class="preview-name">{{item.name}}</text>
        <text class="preview-calories">{{item.calories}}千卡</text>
      </view>
    </view>
  </view>

  <!-- 今日运动预览 -->
  <view class="preview-card" wx:if="{{todayExercise.length > 0}}">
    <view class="preview-header">
      <view class="preview-title-row">
        <view class="preview-icon-wrap exercise-bg">
          <text class="preview-emoji">🏃</text>
        </view>
        <text class="preview-title">今日运动</text>
      </view>
      <text class="preview-count">{{todayExercise.length}}项</text>
    </view>
    <view class="preview-list">
      <view
        wx:for="{{todayExercise}}"
        wx:key="id"
        class="preview-item"
      >
        <text class="preview-name">{{item.name}}</text>
        <text class="preview-calories">{{item.calories}}千卡</text>
      </view>
    </view>
  </view>

  <!-- 健康提示 -->
  <view class="tip-card">
    <view class="tip-icon-wrap">
      <text class="tip-emoji">💡</text>
    </view>
    <text class="tip-text">保持规律作息，每天饮水2000ml以上，坚持就是胜利！</text>
  </view>
</view>
