/* ========== 饮食录入页面 - 清爽浅绿色 ========== */

.container {
  padding: var(--space-lg);
  padding-bottom: 100px;
}

/* 表单卡片 */
.form-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--space-xl);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.form-group {
  margin-bottom: var(--space-xl);
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

/* 餐次显示 */
.meal-display {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding: var(--space-md) var(--space-lg);
  background: var(--primary-lightest);
  border-radius: var(--radius-sm);
}

.meal-icon {
  font-size: 28px;
}

.meal-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--primary-darker);
}

.meal-time {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-left: auto;
  font-weight: 500;
}

/* 日期显示 */
.date-display {
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 500;
}

/* 输入框 */
.form-input {
  width: 100%;
  padding: 14px var(--space-lg);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  font-size: 16px;
  line-height: 1.5;
  color: var(--text-primary);
  box-sizing: border-box;
  border: 1.5px solid var(--gray-200);
  min-height: 48px;
}

.input-with-unit {
  display: flex;
  align-items: center;
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 0 var(--space-lg);
  border: 1.5px solid var(--gray-200);
}

.input-with-unit .form-input {
  flex: 1;
  background: transparent;
  padding: 14px 0;
  font-size: 16px;
  line-height: 1.5;
  min-height: 48px;
  border: none;
}

.input-unit {
  font-size: var(--font-md);
  color: var(--text-secondary);
  margin-left: var(--space-sm);
  font-weight: 500;
}

/* 营养素输入 */
.nutrition-inputs {
  display: flex;
  gap: var(--space-md);
}

.nutrition-input-item {
  flex: 1;
}

.nutrition-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-bottom: 6px;
  text-align: center;
  font-weight: 600;
}

.input-with-unit.small .form-input {
  padding: 12px 0;
  text-align: center;
  font-size: 16px;
  min-height: 44px;
}

/* 提示区域 */
.tips-section {
  background: var(--warning-light);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  border-left: 4px solid var(--warning);
}

.tips-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 700;
  color: #E65100;
  margin-bottom: var(--space-sm);
}

.tips-item {
  display: block;
  font-size: var(--font-sm);
  color: #E65100;
  line-height: 1.8;
  font-weight: 500;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: var(--space-md);
  padding: var(--space-md) var(--space-lg) calc(var(--space-md) + env(safe-area-inset-bottom));
  background: var(--bg-white);
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.bottom-bar .btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
  border-radius: var(--radius-sm);
  font-size: var(--font-md);
  font-weight: 600;
}

.btn-ghost {
  background: var(--bg-page);
  color: var(--text-secondary);
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: var(--text-white);
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}
