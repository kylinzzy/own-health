/* 指南详情页面样式 */

.container {
  padding: 16px;
}

/* 头部 */
.detail-header {
  text-align: center;
  padding: 24px 16px;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  border-radius: 16px;
  margin-bottom: 20px;
}

.header-icon {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}

.header-title {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6px;
}

.header-subtitle {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

/* 区块 */
.section {
  margin-bottom: 20px;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12px;
}

.title-icon {
  font-size: 18px;
  margin-right: 8px;
}

/* 原则列表 */
.principles-list {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.principle-item {
  display: flex;
  align-items: flex-start;
  padding: 12px 0;
  border-bottom: 1px solid #F5F5F5;
}

.principle-item:last-child {
  border-bottom: none;
}

.principle-number {
  width: 24px;
  height: 24px;
  background: #2ECC71;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 600;
  margin-right: 12px;
  flex-shrink: 0;
  margin-top: 2px;
}

.principle-text {
  flex: 1;
  font-size: 14px;
  color: #2C3E50;
  line-height: 1.6;
}

/* 警告列表 */
.warnings-list {
  background: #FFF5F5;
  border-radius: 12px;
  padding: 16px;
  border-left: 4px solid #E74C3C;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  padding: 8px 0;
}

.warning-icon {
  width: 18px;
  height: 18px;
  background: #E74C3C;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  margin-right: 10px;
  flex-shrink: 0;
  margin-top: 2px;
}

.warning-text {
  flex: 1;
  font-size: 14px;
  color: #C0392B;
  line-height: 1.6;
}

/* 提示卡片 */
.tips-card {
  background: #F0F9FF;
  border-radius: 12px;
  padding: 16px;
  border-left: 4px solid #3498DB;
}

.tips-text {
  font-size: 14px;
  color: #2C3E50;
  line-height: 1.6;
}
