/* ========== 膳食指南页面 - 清爽浅绿色 ========== */

/* 搜索栏 */
.search-bar {
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-white);
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg-page);
  border-radius: var(--radius-full);
  padding: var(--space-sm) var(--space-lg);
}

.search-icon {
  font-size: var(--font-md);
  margin-right: var(--space-sm);
  color: var(--text-light);
}

.search-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--text-primary);
}

.clear-icon {
  font-size: var(--font-md);
  color: var(--text-light);
  padding: var(--space-xs);
}

/* 搜索结果 */
.search-results {
  padding: 0 var(--space-lg);
}

.result-count {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--space-sm);
  font-weight: 500;
}

.result-item {
  margin-bottom: var(--space-sm);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.result-icon {
  font-size: 20px;
  margin-right: var(--space-sm);
}

.result-title {
  flex: 1;
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
}

.result-type {
  font-size: var(--font-xs);
  color: var(--primary-dark);
  background: var(--primary-lightest);
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.result-content {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
}

.result-tips {
  display: flex;
  flex-wrap: wrap;
}

.tip-tag {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  background: var(--bg-page);
  padding: 3px 10px;
  border-radius: var(--radius-full);
  margin-right: var(--space-sm);
  margin-bottom: var(--space-xs);
  font-weight: 500;
}

.result-note {
  font-size: var(--font-sm);
  color: var(--warning);
  margin-top: var(--space-sm);
  font-weight: 500;
}

/* 标签页导航 */
.tab-nav {
  display: flex;
  background: var(--bg-white);
  padding: 0 var(--space-lg);
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-md) 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 3px;
  background: var(--primary);
  border-radius: 2px;
}

.tab-icon {
  font-size: 20px;
  margin-bottom: 4px;
}

.tab-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: var(--primary-dark);
  font-weight: 700;
}

/* 内容区域 */
.tab-content {
  padding: 0 var(--space-lg) var(--space-2xl);
}

/* 膳食宝塔 */
.pagoda-container {
  display: flex;
  flex-direction: column-reverse;
}

.pagoda-level {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-card);
}

.level-content {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
}

.level-icon {
  font-size: 32px;
  margin-right: var(--space-md);
}

.level-info {
  flex: 1;
}

.level-name {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.level-recommendation {
  font-size: var(--font-sm);
  color: var(--primary-dark);
  font-weight: 600;
}

.level-tips {
  display: flex;
  flex-wrap: wrap;
  padding-left: 44px;
}

.tip-item {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-right: var(--space-lg);
  margin-bottom: var(--space-xs);
  font-weight: 500;
}

/* 不同层级颜色 */
.level-5 { border-left: 4px solid var(--danger); }
.level-4 { border-left: 4px solid var(--warning); }
.level-3 { border-left: 4px solid #AB47BC; }
.level-2 { border-left: 4px solid var(--info); }
.level-1 { border-left: 4px solid var(--primary); }

/* 营养素网格 */
.nutrient-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-md);
}

.nutrient-card {
  padding: var(--space-lg);
}

.nutrient-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
}

.nutrient-icon {
  font-size: 24px;
  margin-right: var(--space-sm);
}

.nutrient-name {
  font-size: var(--font-base);
  font-weight: 700;
  color: var(--text-primary);
}

.nutrient-values {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-sm);
}

.nutrient-value {
  display: flex;
  align-items: baseline;
}

.value-number {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--primary-dark);
}

.value-unit {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-left: 2px;
  font-weight: 500;
}

.value-gender {
  font-size: var(--font-xs);
  color: var(--text-light);
  margin-left: 4px;
}

.nutrient-divider {
  margin: 0 var(--space-sm);
  color: var(--text-light);
  font-size: var(--font-md);
}

.nutrient-note {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

/* 人群列表 */
.group-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.group-card {
  padding: var(--space-lg);
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
}

.group-icon {
  font-size: 28px;
  margin-right: var(--space-md);
}

.group-name {
  flex: 1;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.group-arrow {
  font-size: 20px;
  color: var(--text-light);
}

.group-principles {
  margin-bottom: var(--space-md);
}

.principle-item {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.8;
  padding-left: 40px;
}

.group-warnings {
  display: flex;
  flex-wrap: wrap;
  padding-left: 40px;
}

.warning-tag {
  font-size: var(--font-xs);
  color: var(--danger);
  background: var(--danger-light);
  padding: 3px 10px;
  border-radius: var(--radius-full);
  margin-right: var(--space-sm);
  margin-bottom: var(--space-xs);
  font-weight: 600;
}

/* 禁忌列表 */
.taboo-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.taboo-card {
  padding: var(--space-lg);
}

.taboo-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
}

.taboo-icon {
  font-size: 24px;
  margin-right: var(--space-md);
}

.taboo-category {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.taboo-items {
  padding-left: 36px;
}

.taboo-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: var(--space-sm);
}

.taboo-dot {
  color: var(--danger);
  margin-right: var(--space-sm);
  font-size: var(--font-md);
  line-height: 1.5;
  font-weight: 700;
}

.taboo-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.6;
}
