/* 膳食指南页面样式 */

/* 搜索栏 */
.search-bar {
  padding: 12px 16px;
  background: #FFFFFF;
  margin-bottom: 12px;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 20px;
  padding: 8px 12px;
}

.search-icon {
  font-size: 16px;
  margin-right: 8px;
  color: #7F8C8D;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #2C3E50;
}

.search-input::placeholder {
  color: #BDC3C7;
}

.clear-icon {
  font-size: 14px;
  color: #BDC3C7;
  padding: 4px;
}

/* 搜索结果 */
.search-results {
  padding: 0 16px;
}

.result-count {
  font-size: 12px;
  color: #7F8C8D;
  margin-bottom: 8px;
}

.result-item {
  margin-bottom: 8px;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.result-icon {
  font-size: 20px;
  margin-right: 8px;
}

.result-title {
  flex: 1;
  font-size: 15px;
  font-weight: 600;
  color: #2C3E50;
}

.result-type {
  font-size: 11px;
  color: #2ECC71;
  background: rgba(46, 204, 113, 0.1);
  padding: 2px 8px;
  border-radius: 10px;
}

.result-content {
  font-size: 13px;
  color: #2C3E50;
  line-height: 1.6;
  margin-bottom: 8px;
}

.result-tips {
  display: flex;
  flex-wrap: wrap;
}

.tip-tag {
  font-size: 11px;
  color: #7F8C8D;
  background: #F5F5F5;
  padding: 3px 8px;
  border-radius: 4px;
  margin-right: 6px;
  margin-bottom: 4px;
}

.result-note {
  font-size: 12px;
  color: #F39C12;
  margin-top: 6px;
}

/* 标签页导航 */
.tab-nav {
  display: flex;
  background: #FFFFFF;
  padding: 0 16px;
  margin-bottom: 12px;
  border-radius: 0 0 12px 12px;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 3px;
  background: #2ECC71;
  border-radius: 2px;
}

.tab-icon {
  font-size: 20px;
  margin-bottom: 4px;
}

.tab-label {
  font-size: 12px;
  color: #7F8C8D;
}

.tab-item.active .tab-label {
  color: #2ECC71;
  font-weight: 500;
}

/* 内容区域 */
.tab-content {
  padding: 0 16px 24px;
}

.section-header {
  margin-bottom: 16px;
}

.section-title {
  display: block;
  font-size: 18px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 4px;
}

.section-desc {
  font-size: 13px;
  color: #7F8C8D;
}

/* 膳食宝塔 */
.pagoda-container {
  display: flex;
  flex-direction: column-reverse;
}

.pagoda-level {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 8px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.level-content {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.level-icon {
  font-size: 32px;
  margin-right: 12px;
}

.level-info {
  flex: 1;
}

.level-name {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 4px;
}

.level-recommendation {
  font-size: 13px;
  color: #2ECC71;
  font-weight: 500;
}

.level-tips {
  display: flex;
  flex-wrap: wrap;
  padding-left: 44px;
}

.tip-item {
  font-size: 12px;
  color: #7F8C8D;
  margin-right: 12px;
  margin-bottom: 4px;
}

/* 不同层级颜色 */
.level-5 { border-left: 4px solid #E74C3C; }
.level-4 { border-left: 4px solid #F39C12; }
.level-3 { border-left: 4px solid #9B59B6; }
.level-2 { border-left: 4px solid #3498DB; }
.level-1 { border-left: 4px solid #2ECC71; }

/* 营养素网格 */
.nutrient-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.nutrient-card {
  padding: 14px;
}

.nutrient-header {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.nutrient-icon {
  font-size: 24px;
  margin-right: 8px;
}

.nutrient-name {
  font-size: 14px;
  font-weight: 600;
  color: #2C3E50;
}

.nutrient-values {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.nutrient-value {
  display: flex;
  align-items: baseline;
}

.value-number {
  font-size: 20px;
  font-weight: 700;
  color: #2ECC71;
}

.value-unit {
  font-size: 11px;
  color: #7F8C8D;
  margin-left: 2px;
}

.value-gender {
  font-size: 11px;
  color: #BDC3C7;
  margin-left: 4px;
}

.nutrient-divider {
  margin: 0 8px;
  color: #BDC3C7;
  font-size: 14px;
}

.nutrient-note {
  font-size: 11px;
  color: #7F8C8D;
}

/* 人群列表 */
.group-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.group-card {
  padding: 16px;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.group-icon {
  font-size: 28px;
  margin-right: 10px;
}

.group-name {
  flex: 1;
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
}

.group-arrow {
  font-size: 20px;
  color: #BDC3C7;
}

.group-principles {
  margin-bottom: 10px;
}

.principle-item {
  display: block;
  font-size: 13px;
  color: #2C3E50;
  line-height: 1.8;
  padding-left: 38px;
}

.group-warnings {
  display: flex;
  flex-wrap: wrap;
  padding-left: 38px;
}

.warning-tag {
  font-size: 11px;
  color: #E74C3C;
  background: rgba(231, 76, 60, 0.08);
  padding: 3px 8px;
  border-radius: 4px;
  margin-right: 6px;
  margin-bottom: 4px;
}

/* 禁忌列表 */
.taboo-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.taboo-card {
  padding: 16px;
}

.taboo-header {
  display: flex;
  align-items: center;
  margin-bottom: 12px;
}

.taboo-icon {
  font-size: 24px;
  margin-right: 10px;
}

.taboo-category {
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
}

.taboo-items {
  padding-left: 34px;
}

.taboo-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8px;
}

.taboo-dot {
  color: #E74C3C;
  margin-right: 8px;
  font-size: 14px;
  line-height: 1.5;
}

.taboo-text {
  flex: 1;
  font-size: 13px;
  color: #2C3E50;
  line-height: 1.5;
}
