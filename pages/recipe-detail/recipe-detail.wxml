<view class="container" wx:if="{{recipe}}">
  <!-- 头部信息 -->
  <view class="recipe-header">
    <view class="header-top">
      <view class="recipe-title-section">
        <text class="recipe-name">{{recipe.name}}</text>
        <view class="recipe-meta">
          <text class="meal-badge">{{mealTypes[recipe.mealType]?.label || recipe.mealType}}</text>
          <text class="meta-item">⏱️ {{recipe.prepTime}}分钟</text>
          <text class="meta-item">{{recipe.difficulty}}</text>
        </view>
      </view>
      <view class="favorite-btn" bindtap="toggleFavorite">
        <text class="favorite-icon {{isFavorite ? 'active' : ''}}">
          {{isFavorite ? '★' : '☆'}}
        </text>
      </view>
    </view>

    <!-- 营养统计 -->
    <view class="nutrition-stats">
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.calories}}</text>
        <text class="nutrition-label">千卡</text>
      </view>
      <view class="nutrition-divider"></view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.protein}}g</text>
        <text class="nutrition-label">蛋白质</text>
      </view>
      <view class="nutrition-divider"></view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.carbs}}g</text>
        <text class="nutrition-label">碳水</text>
      </view>
      <view class="nutrition-divider"></view>
      <view class="nutrition-item">
        <text class="nutrition-value">{{recipe.fat}}g</text>
        <text class="nutrition-label">脂肪</text>
      </view>
    </view>

    <!-- 标签 -->
    <view class="recipe-tags">
      <text 
        wx:for="{{recipe.tags}}" 
        wx:for-item="tag"
        wx:key="tag"
        class="tag tag-primary"
      >
        {{tags.find(t => t.key === tag)?.label || tag}}
      </text>
    </view>
  </view>

  <!-- 食材清单 -->
  <view class="section">
    <view class="section-title">
      <text class="title-icon">🥘</text>
      <text>食材清单</text>
      <text class="ingredient-count">{{recipe.ingredients.length}}种</text>
    </view>
    <view class="ingredients-list">
      <view 
        wx:for="{{recipe.ingredients}}" 
        wx:key="name"
        class="ingredient-item"
      >
        <text class="ingredient-name">{{item.name}}</text>
        <text class="ingredient-amount">{{item.amount}}</text>
      </view>
    </view>
  </view>

  <!-- 制作步骤 -->
  <view class="section">
    <view class="section-title">
      <text class="title-icon">👨‍🍳</text>
      <text>制作步骤</text>
    </view>
    <view class="steps-list">
      <view 
        wx:for="{{recipe.steps}}" 
        wx:key="index"
        class="step-item"
      >
        <view class="step-number">{{index + 1}}</view>
        <text class="step-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 小贴士 -->
  <view class="section" wx:if="{{recipe.tips}}">
    <view class="section-title">
      <text class="title-icon">💡</text>
      <text>小贴士</text>
    </view>
    <view class="tips-card">
      <text class="tips-text">{{recipe.tips}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="action-btn btn-primary" bindtap="addToDietRecord">
      <text class="btn-icon">+</text>
      <text>添加到今日饮食</text>
    </view>
  </view>
</view>
