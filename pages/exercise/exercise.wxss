/* ========== 运动记录页面 - 清爽浅绿色 ========== */

/* 热量缺口卡片 */
.deficit-card {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 50%, #43A047 100%);
  border-radius: var(--radius-xl);
  padding: var(--space-2xl) var(--space-xl);
  margin-bottom: var(--space-lg);
  margin-top: var(--space-sm);
  color: var(--text-white);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.deficit-card::before {
  content: '';
  position: absolute;
  top: -20px;
  right: -20px;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.deficit-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: var(--space-sm);
  margin-bottom: var(--space-sm);
  position: relative;
  z-index: 1;
}

.deficit-title {
  font-size: var(--font-md);
  opacity: 0.9;
  margin-right: var(--space-sm);
  font-weight: 600;
}

.deficit-value {
  font-size: 44px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -1px;
}

.deficit-value.negative {
  color: #C8E6C9;
}

.deficit-value.positive {
  color: #FFCDD2;
}

.deficit-unit {
  font-size: var(--font-md);
  opacity: 0.8;
  font-weight: 500;
}

.deficit-hint {
  font-size: var(--font-sm);
  opacity: 0.9;
  line-height: 1.5;
  margin-top: var(--space-xs);
  position: relative;
  z-index: 1;
  font-weight: 500;
}

/* 周统计 */
.weekly-stats {
  margin-bottom: var(--space-lg);
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: var(--space-md) 0;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stats-number {
  font-size: var(--font-2xl);
  font-weight: 800;
  color: var(--primary-dark);
  line-height: 1.1;
}

.stats-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 600;
}

/* 运动列表 */
.exercise-section {
  margin-bottom: 80px;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.exercise-item {
  display: flex;
  align-items: center;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.exercise-icon {
  font-size: 32px;
  margin-right: var(--space-lg);
  flex-shrink: 0;
}

.exercise-info {
  flex: 1;
}

.exercise-name {
  display: block;
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
}

.exercise-meta {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.meta-tag {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  background: var(--bg-page);
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-weight: 500;
}

.meta-tag.intensity-low {
  color: var(--primary-dark);
  background: var(--primary-lightest);
}

.meta-tag.intensity-medium {
  color: #E65100;
  background: var(--warning-light);
}

.meta-tag.intensity-high {
  color: #C62828;
  background: var(--danger-light);
}

.meta-tag.intensity-veryHigh {
  color: #6A1B9A;
  background: #F3E5F5;
}

.exercise-burn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: var(--space-md);
}

.burn-value {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--danger);
  line-height: 1.1;
}

.burn-unit {
  font-size: 10px;
  color: var(--text-secondary);
  font-weight: 500;
}

.exercise-actions {
  flex-shrink: 0;
}

.delete-btn {
  font-size: var(--font-sm);
  color: var(--danger);
  padding: var(--space-sm) var(--space-md);
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px var(--space-xl);
  background: var(--bg-white);
  border-radius: var(--radius-lg);
}

.empty-icon {
  font-size: 56px;
  margin-bottom: var(--space-lg);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-weight: 600;
}

.empty-subtext {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}
