/* 运动记录页面样式 */

/* 日期栏 */
.date-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  padding: 12px 16px;
  margin-bottom: 12px;
  border-radius: 0 0 12px 12px;
}

.date-nav-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.nav-arrow {
  font-size: 20px;
  color: #2C3E50;
  font-weight: 300;
}

.date-display {
  flex: 1;
  text-align: center;
}

.date-picker {
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.date-text {
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
}

.date-weekday {
  font-size: 13px;
  color: #7F8C8D;
}

.date-arrow {
  font-size: 10px;
  color: #BDC3C7;
  margin-left: 4px;
}

/* 热量缺口卡片 */
.deficit-card {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  border-radius: 16px;
  padding: 24px 20px;
  margin-bottom: 12px;
  margin-top: 8px;
  color: #FFFFFF;
  text-align: center;
}

.deficit-header {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4px;
  margin-bottom: 8px;
}

.deficit-title {
  font-size: 14px;
  opacity: 0.9;
  margin-right: 8px;
}

.deficit-value {
  font-size: 36px;
  font-weight: 700;
  line-height: 1.2;
}

.deficit-value.negative {
  color: #A8E6CF;
}

.deficit-value.positive {
  color: #FFE5E5;
}

.deficit-unit {
  font-size: 14px;
  opacity: 0.8;
}

.deficit-hint {
  font-size: 14px;
  opacity: 0.9;
  line-height: 1.4;
  margin-top: 4px;
}

/* 周统计 */
.weekly-stats {
  margin-bottom: 12px;
}

.stats-header {
  margin-bottom: 12px;
}

.stats-title {
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
  padding: 8px 0;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-number {
  font-size: 24px;
  font-weight: 700;
  color: #2ECC71;
}

.stats-label {
  font-size: 12px;
  color: #7F8C8D;
  margin-top: 2px;
}

/* 运动列表 */
.exercise-section {
  margin-bottom: 80px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
  padding: 0 4px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #2C3E50;
}

.record-count {
  font-size: 12px;
  color: #7F8C8D;
}

.exercise-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.exercise-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12px;
  padding: 14px 16px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.exercise-icon {
  font-size: 28px;
  margin-right: 12px;
}

.exercise-info {
  flex: 1;
}

.exercise-name {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 4px;
}

.exercise-meta {
  display: flex;
  gap: 6px;
}

.meta-tag {
  font-size: 11px;
  color: #7F8C8D;
  background: #F5F5F5;
  padding: 2px 8px;
  border-radius: 10px;
}

.meta-tag.intensity-low {
  color: #2ECC71;
  background: rgba(46, 204, 113, 0.1);
}

.meta-tag.intensity-medium {
  color: #F39C12;
  background: rgba(243, 156, 18, 0.1);
}

.meta-tag.intensity-high {
  color: #E74C3C;
  background: rgba(231, 76, 60, 0.1);
}

.meta-tag.intensity-veryHigh {
  color: #9B59B6;
  background: rgba(155, 89, 182, 0.1);
}

.exercise-burn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 12px;
}

.burn-value {
  font-size: 18px;
  font-weight: 700;
  color: #E74C3C;
}

.burn-unit {
  font-size: 10px;
  color: #7F8C8D;
}

.exercise-actions {
  flex-shrink: 0;
}

.delete-btn {
  font-size: 12px;
  color: #E74C3C;
  padding: 4px 8px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 16px;
  background: #FFFFFF;
  border-radius: 12px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: #2C3E50;
  margin-bottom: 6px;
}

.empty-subtext {
  font-size: 13px;
  color: #7F8C8D;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 16px;
  bottom: calc(16px + env(safe-area-inset-bottom) + 60px);
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: #2ECC71;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  font-weight: 300;
  box-shadow: 0 4px 16px rgba(46, 204, 113, 0.4);
  z-index: 100;
}

.fab:active {
  transform: scale(0.95);
}
