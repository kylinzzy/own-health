/* ========== 饮食记录页面 - 清爽浅绿色 ========== */

/* 每日统计 */
.daily-stats {
  margin-bottom: var(--space-lg);
  border-left: 4px solid var(--primary);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-lg);
}

.stats-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
}

.stats-calories {
  font-size: var(--font-xl);
  font-weight: 800;
  color: var(--primary-dark);
}

/* 营养素进度条 */
.nutrition-bars {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.nutrition-bar-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 600;
}

.bar-track {
  width: 100%;
  height: 8px;
  background: var(--gray-200);
  border-radius: var(--radius-full);
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  transition: width 0.4s ease;
}

.bar-fill.protein {
  background: linear-gradient(90deg, #EF5350, #E57373);
}

.bar-fill.carbs {
  background: linear-gradient(90deg, #29B6F6, #4FC3F7);
}

.bar-fill.fat {
  background: linear-gradient(90deg, #FFA726, #FFB74D);
}

/* 餐次卡片 */
.meals-section {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: var(--space-3xl);
}

.meal-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-md);
}

.meal-info {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.meal-icon {
  font-size: 28px;
}

.meal-title-group {
  display: flex;
  flex-direction: column;
}

.meal-name {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--text-primary);
}

.meal-time {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
  font-weight: 500;
}

.meal-calories {
  display: flex;
  align-items: baseline;
  gap: 3px;
}

.calories-value {
  font-size: var(--font-2xl);
  font-weight: 800;
  color: var(--primary-dark);
  line-height: 1;
}

.calories-unit {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

/* 餐次记录 - 左滑删除 */
.meal-records {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

.record-item {
  position: relative;
  display: flex;
  align-items: center;
  border-radius: var(--radius-sm);
  overflow: hidden;
  transition: transform 0.2s ease;
}

.record-content {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  z-index: 1;
}

.record-info {
  flex: 1;
}

.record-name {
  display: block;
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 4px;
}

.record-nutrition {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.nutrition-tag {
  font-size: 10px;
  color: var(--text-secondary);
  background: var(--bg-white);
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-weight: 500;
}

.record-delete {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--danger);
  z-index: 0;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
}

.delete-text {
  font-size: var(--font-sm);
  color: var(--text-white);
  font-weight: 600;
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-md);
  border: 2px dashed var(--primary-lighter);
  border-radius: var(--radius-sm);
  gap: var(--space-sm);
  background: var(--primary-lightest);
}

.add-icon {
  font-size: 18px;
  color: var(--primary);
  font-weight: 500;
}

.add-text {
  font-size: var(--font-sm);
  color: var(--primary-dark);
  font-weight: 600;
}

.add-btn:active {
  background: var(--primary-lighter);
}
