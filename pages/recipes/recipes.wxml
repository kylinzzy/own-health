<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        type="text" 
        placeholder="搜索食谱或食材..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
      <text wx:if="{{searchKeyword}}" class="clear-icon" bindtap="clearSearch">✕</text>
    </view>
    <view class="filter-btn" bindtap="toggleFilters">
      <text>筛选</text>
      <text class="filter-arrow {{showFilters ? 'up' : ''}}">▼</text>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view wx:if="{{showFilters}}" class="filter-panel">
    <!-- 餐次筛选 -->
    <view class="filter-section">
      <text class="filter-label">餐次</text>
      <view class="filter-options">
        <view 
          wx:for="{{mealTypes}}" 
          wx:key="key"
          class="filter-option {{activeMealType === item.key ? 'active' : ''}}"
          data-type="{{item.key}}"
          bindtap="selectMealType"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 热量筛选 -->
    <view class="filter-section">
      <text class="filter-label">热量</text>
      <view class="filter-options">
        <view 
          wx:for="{{calorieRanges}}" 
          wx:key="key"
          class="filter-option {{activeCalorieRange === item.key ? 'active' : ''}}"
          data-range="{{item.key}}"
          bindtap="selectCalorieRange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 标签筛选 -->
    <view class="filter-section">
      <text class="filter-label">标签</text>
      <view class="filter-options">
        <view 
          wx:for="{{tags}}" 
          wx:key="key"
          class="filter-option {{activeTag === item.key ? 'active' : ''}}"
          data-tag="{{item.key}}"
          bindtap="selectTag"
        >
          {{item.label}}
        </view>
      </view>
    </view>
  </view>

  <!-- 食谱列表 -->
  <view class="recipe-list">
    <view 
      wx:for="{{filteredRecipes}}" 
      wx:key="id"
      class="recipe-card"
      data-id="{{item.id}}"
      bindtap="viewRecipeDetail"
    >
      <!-- 收藏按钮 -->
      <view class="favorite-btn" catchtap="toggleFavorite" data-id="{{item.id}}">
        <text class="favorite-icon {{favorites.includes(item.id) ? 'active' : ''}}">
          {{favorites.includes(item.id) ? '★' : '☆'}}
        </text>
      </view>

      <view class="recipe-header">
        <view class="recipe-info">
          <text class="recipe-name">{{item.name}}</text>
          <view class="recipe-meta">
            <text class="meal-type">{{mealTypes.find(m => m.key === item.mealType)?.label || item.mealType}}</text>
            <text class="prep-time">⏱️ {{item.prepTime}}分钟</text>
            <text class="difficulty">{{item.difficulty}}</text>
          </view>
        </view>
      </view>

      <view class="recipe-stats">
        <view class="stat-item">
          <text class="stat-value">{{item.calories}}</text>
          <text class="stat-unit">千卡</text>
        </view>
        <view class="stat-divider">|</view>
        <view class="stat-item">
          <text class="stat-value">{{item.protein}}g</text>
          <text class="stat-unit">蛋白质</text>
        </view>
        <view class="stat-divider">|</view>
        <view class="stat-item">
          <text class="stat-value">{{item.carbs}}g</text>
          <text class="stat-unit">碳水</text>
        </view>
        <view class="stat-divider">|</view>
        <view class="stat-item">
          <text class="stat-value">{{item.fat}}g</text>
          <text class="stat-unit">脂肪</text>
        </view>
      </view>

      <view class="recipe-tags">
        <text 
          wx:for="{{item.tags}}" 
          wx:for-item="tag"
          wx:key="tag"
          class="tag tag-primary"
        >
          {{tags.find(t => t.key === tag)?.label || tag}}
        </text>
      </view>

      <view class="recipe-ingredients">
        <text class="ingredients-label">食材：</text>
        <text class="ingredients-text">{{item.ingredients.map(i => i.name).join('、')}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{filteredRecipes.length === 0}}" class="empty-state">
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">没有找到符合条件的食谱</text>
    <text class="empty-subtext">试试调整筛选条件</text>
  </view>
</view>
