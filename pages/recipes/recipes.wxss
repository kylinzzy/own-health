/* ========== 减脂食谱页面 - 清爽浅绿色 ========== */

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-white);
  gap: var(--space-md);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg-page);
  border-radius: var(--radius-full);
  padding: var(--space-sm) var(--space-lg);
}

.search-icon {
  font-size: var(--font-md);
  margin-right: var(--space-sm);
  color: var(--text-light);
}

.search-input {
  flex: 1;
  font-size: var(--font-base);
  color: var(--text-primary);
}

.clear-icon {
  font-size: var(--font-md);
  color: var(--text-light);
  padding: var(--space-xs);
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: var(--space-sm) var(--space-lg);
  background: var(--primary-lightest);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--primary-dark);
  font-weight: 600;
}

.filter-arrow {
  font-size: 10px;
  margin-left: 4px;
  transition: transform 0.2s;
}

.filter-arrow.up {
  transform: rotate(180deg);
}

/* 筛选面板 */
.filter-panel {
  background: var(--bg-white);
  padding: var(--space-lg);
  margin-bottom: var(--space-lg);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.filter-section {
  margin-bottom: var(--space-lg);
}

.filter-section:last-child {
  margin-bottom: 0;
}

.filter-label {
  display: block;
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.filter-option {
  padding: 6px 16px;
  background: var(--bg-page);
  border-radius: var(--radius-full);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: 500;
  transition: all 0.2s;
}

.filter-option.active {
  background: var(--primary);
  color: var(--text-white);
  font-weight: 600;
}

/* 食谱列表 */
.recipe-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.recipe-card {
  position: relative;
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

/* 收藏按钮 */
.favorite-btn {
  position: absolute;
  top: var(--space-md);
  right: var(--space-lg);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  background: var(--bg-page);
  border-radius: var(--radius-full);
}

.favorite-icon {
  font-size: 20px;
  color: var(--text-light);
}

.favorite-icon.active {
  color: #FFA726;
}

/* 食谱头部 */
.recipe-header {
  margin-bottom: var(--space-md);
  padding-right: 44px;
}

.recipe-name {
  display: block;
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.recipe-meta {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.meal-type {
  font-size: var(--font-xs);
  color: var(--primary-dark);
  background: var(--primary-lightest);
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.prep-time {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.difficulty {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

/* 统计数据 */
.recipe-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: var(--space-md) 0;
  border-top: 1px solid var(--gray-200);
  border-bottom: 1px solid var(--gray-200);
  margin-bottom: var(--space-md);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: var(--font-lg);
  font-weight: 800;
  color: var(--text-primary);
}

.stat-unit {
  font-size: 10px;
  color: var(--text-secondary);
  margin-top: 2px;
  font-weight: 500;
}

.stat-divider {
  color: var(--gray-300);
  font-size: var(--font-sm);
}

/* 标签 */
.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-bottom: var(--space-md);
}

/* 食材 */
.recipe-ingredients {
  display: flex;
  align-items: flex-start;
}

.ingredients-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  flex-shrink: 0;
  font-weight: 600;
}

.ingredients-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px var(--space-xl);
}

.empty-icon {
  font-size: 56px;
  margin-bottom: var(--space-lg);
  opacity: 0.4;
}

.empty-text {
  font-size: var(--font-md);
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
  font-weight: 600;
}

.empty-subtext {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}
