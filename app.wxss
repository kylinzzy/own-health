/**
 * 全局样式文件
 * 定义CSS变量、工具类、通用组件样式
 */

/* ========== CSS变量 ========== */
page {
  --primary: #2ECC71;
  --primary-light: #58D68D;
  --primary-dark: #27AE60;
  --secondary: #3498DB;
  --accent: #E74C3C;
  --warning: #F39C12;
  
  --bg-primary: #F8F9FA;
  --bg-white: #FFFFFF;
  --bg-card: #FFFFFF;
  --bg-tag: #F0F0F0;
  
  --text-primary: #2C3E50;
  --text-secondary: #7F8C8D;
  --text-light: #BDC3C7;
  --text-white: #FFFFFF;
  
  --border-color: #ECF0F1;
  --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  --shadow-light: 0 1px 4px rgba(0, 0, 0, 0.04);
  
  --radius-lg: 16px;
  --radius-md: 12px;
  --radius-sm: 8px;
  --radius-xs: 4px;
  
  --spacing-lg: 24px;
  --spacing-md: 16px;
  --spacing-sm: 12px;
  --spacing-xs: 8px;
  
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-size: 16px;
  line-height: 1.6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* ========== 通用容器 ========== */
.container {
  padding: var(--spacing-md);
  min-height: 100vh;
  box-sizing: border-box;
}

.container-safe {
  padding: var(--spacing-md);
  padding-bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* ========== 卡片样式 ========== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-light);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.card-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.card-subtitle {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 2px;
}

/* ========== 按钮样式 ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 24px;
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-weight: 500;
  border: none;
  transition: opacity 0.2s;
}

.btn:active {
  opacity: 0.8;
}

.btn-primary {
  background: var(--primary);
  color: var(--text-white);
}

.btn-secondary {
  background: var(--secondary);
  color: var(--text-white);
}

.btn-outline {
  background: transparent;
  border: 1px solid var(--primary);
  color: var(--primary);
}

.btn-ghost {
  background: var(--bg-tag);
  color: var(--text-primary);
}

.btn-block {
  width: 100%;
}

.btn-sm {
  padding: 6px 12px;
  font-size: 12px;
}

/* ========== 标签样式 ========== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: var(--radius-xs);
  font-size: 11px;
  font-weight: 500;
  margin-right: 6px;
  margin-bottom: 6px;
}

.tag-primary {
  background: rgba(46, 204, 113, 0.15);
  color: var(--primary-dark);
}

.tag-secondary {
  background: rgba(52, 152, 219, 0.15);
  color: var(--secondary);
}

.tag-warning {
  background: rgba(243, 156, 18, 0.15);
  color: var(--warning);
}

.tag-accent {
  background: rgba(231, 76, 60, 0.15);
  color: var(--accent);
}

/* ========== 表单样式 ========== */
.form-group {
  margin-bottom: var(--spacing-md);
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.form-input {
  width: 100%;
  padding: 12px;
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 14px;
  background: var(--bg-white);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--primary);
}

/* ========== 列表样式 ========== */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1px solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px var(--spacing-md);
  text-align: center;
}

.empty-icon {
  width: 80px;
  height: 80px;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
}

/* ========== 统计数字 ========== */
.stat-value {
  font-size: 28px;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
}

.stat-unit {
  font-size: 12px;
  color: var(--text-secondary);
  margin-left: 2px;
}

.stat-label {
  font-size: 12px;
  color: var(--text-secondary);
  margin-top: 4px;
}

/* ========== 进度条 ========== */
.progress-bar {
  width: 100%;
  height: 8px;
  background: var(--border-color);
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary);
  border-radius: 4px;
  transition: width 0.3s ease;
}

/* ========== 分割线 ========== */
.divider {
  height: 1px;
  background: var(--border-color);
  margin: var(--spacing-sm) 0;
}

/* ========== 浮动按钮 ========== */
.fab {
  position: fixed;
  right: var(--spacing-md);
  bottom: calc(var(--spacing-md) + env(safe-area-inset-bottom) + 60px);
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--primary);
  color: var(--text-white);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(46, 204, 113, 0.4);
  font-size: 24px;
  font-weight: 300;
  z-index: 100;
}

.fab:active {
  transform: scale(0.95);
}

/* ========== 工具类 ========== */
.flex {
  display: flex;
}

.flex-1 {
  flex: 1;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-accent {
  color: var(--accent);
}

.text-warning {
  color: var(--warning);
}

.font-bold {
  font-weight: 600;
}

.font-lg {
  font-size: 16px;
}

.font-sm {
  font-size: 12px;
}

.mt-sm {
  margin-top: var(--spacing-xs);
}

.mt-md {
  margin-top: var(--spacing-sm);
}

.mb-sm {
  margin-bottom: var(--spacing-xs);
}

.mb-md {
  margin-bottom: var(--spacing-sm);
}

.p-md {
  padding: var(--spacing-md);
}

.rounded {
  border-radius: var(--radius-md);
}

.bg-white {
  background: var(--bg-white);
}

/* ========== 动画 ========== */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* ========== 隐藏滚动条 ========== */
::-webkit-scrollbar {
  display: none;
}
